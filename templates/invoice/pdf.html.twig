<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white p-10 font-sans text-gray-800">

    <div class="flex justify-between items-start mb-8">
        <div>
            <p class="font-bold text-lg">{{ app.user.companyName }}</p>
            <p class="text-sm text-gray-600">{{ app.user.firstName }} {{ app.user.lastName }}</p>
            <p class="text-sm text-gray-600">{{ app.user.email }}</p>
            {% if app.user.siret %}
            <p class="text-sm text-gray-600">SIRET : {{ app.user.siret }}</p>
            {% endif %}
        </div>
        <div class="text-right">
            <p class="font-bold text-2xl tracking-widest">FACTURE</p>
            <p class="text-sm text-gray-600">N° {{ invoice.number }}</p>
            {% if invoice.createAt %}
            <p class="text-sm text-gray-600">Date : {{ invoice.createAt|date('d/m/Y') }}</p>
            {% endif %}
        </div>
    </div>

    {% if invoice.client %}
    <div class="bg-gray-50 rounded-lg p-4 mb-8 ml-auto w-64">
        <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">Facturé à</p>
        <p class="font-bold text-lg">{{ invoice.client.name }}</p>
        {% if invoice.client.address %}<p class="text-sm text-gray-600">{{ invoice.client.address }}</p>{% endif %}
        {% if invoice.client.email %}<p class="text-sm text-gray-600">{{ invoice.client.email }}</p>{% endif %}
        {% if invoice.client.siret %}<p class="text-sm text-gray-600">SIRET : {{ invoice.client.siret }}</p>{% endif %}
    </div>
    {% endif %}

    <table class="w-full mb-6">
        <thead>
            <tr class="border-b border-gray-300">
                <th class="text-left py-3 text-sm font-semibold text-gray-700">Description</th>
                <th class="text-right py-3 text-sm font-semibold text-gray-700">Qté</th>
                <th class="text-right py-3 text-sm font-semibold text-gray-700">Prix Unitaire</th>
                <th class="text-right py-3 text-sm font-semibold text-gray-700">Total TTC</th>
            </tr>
        </thead>
        <tbody>
            {% set total = 0 %}
            {% for product in invoice.products %}
                {% set total = total + (product.price * product.quantity) %}
            <tr class="border-b border-gray-100">
                <td class="py-4">
                    <p class="font-medium">{{ product.name }}</p>
                    <p class="text-sm text-gray-400">{{ product.description }}</p>
                </td>
                <td class="text-right py-4">{{ product.quantity }}</td>
                <td class="text-right py-4">{{ product.price }} €</td>
                <td class="text-right py-4 font-bold">{{ product.price * product.quantity }} €</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="flex justify-end mb-10">
        <div class="w-64">
            <div class="flex justify-between py-2 text-sm text-gray-600">
                <span>Total HT</span>
                <span>{{ total }} €</span>
            </div>
            <div class="flex justify-between py-2 font-bold border-t border-gray-300">
                <span>Total TTC</span>
                <span class="text-lg">{{ total }} €</span>
            </div>
            <p class="text-xs text-gray-400 text-right">TVA non applicable, art. 293 B du CGI</p>
        </div>
    </div>

    <div class="border-t border-gray-200 pt-6">
        {% if invoice.client and invoice.client.rib %}
        <div class="bg-gray-50 rounded-lg p-4 mb-4">
            <p class="text-sm font-medium text-gray-700 mb-1">Conditions de paiement</p>
            <p class="text-sm text-gray-600">Coordonnées bancaires : {{ invoice.client.rib }}</p>
            {% if app.user.iban %}
            <p class="text-sm text-gray-600">IBAN : {{ app.user.iban }}</p>
            {% endif %}
        </div>
        {% endif %}

        {% if app.user.cgv %}
        <div class="mt-4">
            <p class="text-sm font-medium text-gray-700 mb-1">Conditions Générales de Vente</p>
            <p class="text-xs text-gray-500">{{ app.user.cgv }}</p>
        </div>
        {% endif %}
    </div>

</body>
</html>