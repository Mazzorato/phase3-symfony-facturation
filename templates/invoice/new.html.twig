{% extends 'base.html.twig' %}
{% block title %}Créer une Facture{% endblock %}
{% block body %}
<section class="bg-gray-100 min-h-screen p-8">

    <div class="mb-4">
        <a href="{{ path('app_invoice') }}" class="text-gray-500 hover:text-gray-700 text-sm flex items-center gap-2">
            <i class="fa-solid fa-arrow-left"></i> Retour aux factures
        </a>
    </div>

    <h1 class="text-2xl font-bold text-gray-800 mb-6">Créer une facture</h1>

    {{ form_start(form) }}

    <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <h2 class="text-lg font-semibold mb-4">Informations Générales</h2>
        <div class="flex gap-4">
            <div class="flex-1">
                {{ form_label(form.client, 'Client', {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
                <div class="flex gap-2">
                    {{ form_widget(form.client, {'attr': {'class': 'w-full border border-gray-300 rounded-lg px-3 py-2'}}) }}
                    <a href="{{ path('app_client_new') }}" class="flex items-center justify-center w-10 h-10 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-100">
                        <i class="fa-solid fa-plus"></i>
                    </a>
                </div>
            </div>
            <div class="flex-1">
                {{ form_label(form.createAt, 'Date de la facture', {'label_attr': {'class': 'block text-sm text-gray-600 mb-1'}}) }}
                {{ form_widget(form.createAt, {'attr': {'class': 'w-full border border-gray-300 rounded-lg px-3 py-2'}}) }}
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <h2 class="text-lg font-semibold mb-4">Lignes de la facture</h2>
            <twig:invoice_lines :invoice="invoice" />
        {# <table class="w-full mb-6">
            <thead>
                <tr class="border-b">
                    <th class="text-left py-2 text-sm font-semibold text-gray-700">Produit / Service</th>
                    <th class="text-right py-2 text-sm font-semibold text-gray-700">Qté</th>
                    <th class="text-right py-2 text-sm font-semibold text-gray-700">Prix Unitaire</th>
                    <th class="text-right py-2 text-sm font-semibold text-gray-700">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for product in invoice.products %}
                <tr class="border-b">
                    <td class="py-3">
                        <div class="font-medium">{{ product.name }}</div>
                        <div class="text-sm text-gray-400">{{ product.description }}</div>
                    </td>
                    <td class="text-right py-3">{{ product.quantity }}</td>
                    <td class="text-right py-3">{{ product.price }} €</td>
                    <td class="text-right py-3 font-medium">{{ product.price * product.quantity }} €</td>
                    <td class="text-right py-3">
                        <button type="submit" name="remove_line" value="{{ product.id }}" class="text-red-500 hover:text-red-700">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table> #}

        <div class="flex gap-3 items-end">
            <div style="flex: 3">
                <label class="block text-sm text-gray-600 mb-1">Sélectionner un produit</label>
                <input list="products-list" name="product_id" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="Rechercher ou saisir l'ID...">
                <datalist id="products-list">
                    {% for product in products %}
                        <option value="{{ product.id }}">{{ product.name }}</option>
                    {% endfor %}
                </datalist>
            </div>
            <div style="flex: 1">
                <label class="block text-sm text-gray-600 mb-1">Quantité</label>
                <input type="number" name="quantity" value="1" min="1" class="w-full border border-gray-300 rounded-lg px-3 py-2">
            </div>
            <div style="flex: 1">
                <label class="block text-sm text-gray-600 mb-1">Prix unitaire (€)</label>
                <input type="number" name="unit_price" step="0.01" class="w-full border border-gray-300 rounded-lg px-3 py-2">
            </div>
            <div style="flex: 1">
                <button type="submit" name="add_line" value="1" class="w-30 bg-gray-400 text-white px-3 py-2 rounded-lg flex items-center justify-center gap-2 hover:bg-gray-600">
                    <i class="fa-solid fa-plus"></i> Ajouter
                </button>
            </div>
        </div>

        <div class="flex justify-end mt-6">
            <span class="font-semibold text-gray-700 mr-2">Total Facture (TTC) :</span>
            <span class="text-blue-600 font-bold text-xl">
                {% set total = 0 %}
                {% for product in invoice.products %}
                    {% set total = total + (product.price * product.quantity) %}
                {% endfor %}
                {{ total }} €
            </span>
        </div>
    </div>

    <div class="flex justify-center gap-4">
        <a href="{{ path('app_invoice') }}" class="px-6 py-2 border border-gray-300 rounded-lg bg-white text-gray-700 hover:bg-gray-50">Annuler</a>
        <button type="submit" name="status" value="brouillons" class="px-6 py-2 border border-blue-500 text-blue-600 rounded-lg hover:bg-blue-50">Enregistrer en brouillon</button>
        <button type="submit" name="status" value="en_attente" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Enregistrer et valider</button>
    </div>

    {{ form_end(form, {'render_rest': false}) }}

</section>
{% endblock %}