{% extends 'base.html.twig' %}

{% block title %}Edit Product{% endblock %}

{% block body %}
<section class="bg-gray-100 min-h-screen p-6 flex justify-center items-center">
    <div class="w-full max-w-xl bg-white rounded-xl shadow-md p-6 ">
    <p class="text-2xl font-bold text-gray-800 mb-2">Client - {{ client.name }}</p>
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-semibold text-gray-700">Modifier le client</h2>   
            <div class="flex justify-between items-center mb-6">
