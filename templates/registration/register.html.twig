{% extends 'base.html.twig' %}
{% block title %}Register{% endblock %}
{% block body %}
<section class="min-h-screen flex flex-col items-center justify-center bg-gray-50 gap-6">

    <div class="flex flex-col items-center">
        <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center text-white mb-4">
            <i class="fa-solid fa-file-invoice-dollar"></i>
        </div>
        <h1 class="font-bold text-2xl text-gray-900">Créez votre compte</h1>
        <p class="text-sm text-gray-500 mt-1">Ou
            <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">connectez-vous à votre compte</a>
        </p>
    </div>

    {{ form_start(registrationForm, {attr: {class: "bg-white p-8 rounded-xl shadow-sm border border-gray-200 w-full max-w-lg flex flex-col gap-4"}}) }}

        <div class="flex gap-4">
            <div class="flex flex-col gap-1 flex-1">
                {{ form_label(registrationForm.firstName, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(registrationForm.firstName, {attr: {class: 'border border-gray-300 rounded-lg px-4 py-2.5 text-sm w-full', placeholder: 'Jean'}}) }}
            </div>
            <div class="flex flex-col gap-1 flex-1">
                {{ form_label(registrationForm.lastName, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(registrationForm.lastName, {attr: {class: 'border border-gray-300 rounded-lg px-4 py-2.5 text-sm w-full', placeholder: 'Dupont'}}) }}
            </div>
        </div>

        <div class="flex flex-col gap-1">
            {{ form_label(registrationForm.companyName, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(registrationForm.companyName, {attr: {class: 'border border-gray-300 rounded-lg px-4 py-2.5 text-sm w-full', placeholder: 'Tech Solutions'}}) }}
        </div>

        <div class="flex flex-col gap-1">
            {{ form_label(registrationForm.iban, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(registrationForm.iban, {attr: {class: 'border border-gray-300 rounded-lg px-4 py-2.5 text-sm w-full', placeholder: 'FR76 1234 5678 9012 3456 7890 123'}}) }}
        </div>

        <div class="flex flex-col gap-1">
            {{ form_label(registrationForm.email, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(registrationForm.email, {attr: {class: 'border border-gray-300 rounded-lg px-4 py-2.5 text-sm w-full', placeholder: 'contact@entreprise.fr'}}) }}
        </div>

        <div class="flex flex-col gap-1">
            {{ form_label(registrationForm.plainPassword, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(registrationForm.plainPassword, {attr: {class: 'border border-gray-300 rounded-lg px-4 py-2.5 text-sm w-full', placeholder: 'password'}}) }}
        </div>

        <button type="submit" class="w-full bg-blue-600 text-white py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700">
            Créer mon compte
        </button>

    {{ form_end(registrationForm) }}

</section>
{% endblock %}